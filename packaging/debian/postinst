#
# postinst: refresh the system MIME cache so the .j extension is
# recognised right after install. update-mime-database failure is
# non-fatal (it would mean the .j MIME just isn't picked up until
# the next manual refresh).

set -e

case "$1" in
    configure)
        if command -v update-mime-database >/dev/null 2>&1; then
            update-mime-database /usr/share/mime || true
        fi
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        echo "postinst called with unknown argument: $1" >&2
        exit 1
        ;;
esac

exit 0
