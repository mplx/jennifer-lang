# Copyright (C) 2026 mplx <jennifer@mplx.dev>
#
# Multi-stage image for the Jennifer language interpreter. The build context is
# the repo root:
#
#   docker build -f packaging/docker/Dockerfile --target slim -t jennifer .
#
# The build stage runs on the native build platform and cross-compiles both
# binaries to the target arch (Go and TinyGo both honour GOARCH), so a multi-arch
# buildx run needs no emulation to compile. Two selectable final stages:
#
#   slim   (default) - debian:trixie-slim, the full host-feature build: os.run
#                      can shell out, ca-certificates present so net/TLS verify.
#   static           - distroless/static: a near-pure interpreter, ~15-25MB, no
#                      /bin/sh (so os.run of external programs is unavailable).
#
# See packaging/docker/README.md.

# ---- build ----------------------------------------------------------------
FROM --platform=$BUILDPLATFORM golang:1.26.3-bookworm AS build

# The same TinyGo the release pipeline pins (acifani/setup-tinygo), installed
# into the Go 1.26.3 image so both toolchains share that Go - the pairing
# `make build` uses. BUILDARCH (amd64/arm64) matches TinyGo's .deb arch suffix,
# so this works even when the build host itself is arm64.
ARG TINYGO_VERSION=0.41.1
ARG BUILDARCH
RUN set -eux; \
    arch="${BUILDARCH:-amd64}"; \
    deb="tinygo_${TINYGO_VERSION}_${arch}.deb"; \
    wget -q "https://github.com/tinygo-org/tinygo/releases/download/v${TINYGO_VERSION}/${deb}"; \
    apt-get update; \
    apt-get install -y --no-install-recommends "./${deb}"; \
    rm -f "${deb}"; \
    rm -rf /var/lib/apt/lists/*; \
    tinygo version

WORKDIR /src
# Module cache as its own layer so source edits do not re-download deps.
COPY go.mod go.sum ./
RUN go mod download
COPY . .

# Stamp the version into BOTH binaries. TinyGo ignores -ldflags -X, so the
# version has to be baked as generated Go (an init() overriding version.Version),
# exactly as scripts/gen-version.sh does from git state - here from a build arg
# so the image build stays git-free.
ARG VERSION=dev
RUN printf '// SPDX-License-Identifier: LGPL-3.0-only\n// Code generated by the Docker build from the VERSION build arg; DO NOT EDIT.\n\npackage version\n\nfunc init() { Version = "%s" }\n' "$VERSION" \
    > internal/version/version_gen.go

# Cross-compile both binaries to the target arch (flags mirror release.yml), and
# stage the importable modules (minus the *_test.j overlays) plus the docs.
ARG TARGETARCH
RUN set -eux; \
    mkdir -p /out/share/jennifer/modules /out/share/doc/jennifer /out/work; \
    CGO_ENABLED=0 GOARCH="$TARGETARCH" \
        go build -trimpath -ldflags="-s -w" -o /out/jennifer ./cmd/jennifer; \
    GOARCH="$TARGETARCH" \
        tinygo build -scheduler=tasks -stack-size=2mb -no-debug -o /out/jennifer-tiny ./cmd/jennifer; \
    for m in modules/*.j; do \
        case "$m" in *_test.j) continue ;; esac; \
        cp "$m" /out/share/jennifer/modules/; \
    done; \
    cp JENNIFER.md /out/share/doc/jennifer/JENNIFER.md; \
    cp packaging/debian/copyright /out/share/doc/jennifer/LICENSE

# ---- slim (default / :latest) ---------------------------------------------
FROM debian:trixie-slim AS slim
ARG VERSION=dev
LABEL org.opencontainers.image.title="Jennifer" \
      org.opencontainers.image.description="The Jennifer programming language interpreter (full host-feature build)" \
      org.opencontainers.image.url="https://jennifer-lang.dev" \
      org.opencontainers.image.source="https://github.com/jennifer-language/jennifer" \
      org.opencontainers.image.licenses="LGPL-3.0-only" \
      org.opencontainers.image.version="${VERSION}"
# CA certificates so net / http / TLS verify peers out of the box.
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends ca-certificates; \
    rm -rf /var/lib/apt/lists/*; \
    useradd --system --create-home --shell /usr/sbin/nologin --uid 10001 jennifer; \
    mkdir -p /work; \
    chown jennifer:jennifer /work
COPY --from=build /out/jennifer /out/jennifer-tiny /usr/bin/
COPY --from=build /out/share /usr/share
USER jennifer
WORKDIR /work
# `docker run img run app.j`; `docker run -it img repl`.
ENTRYPOINT ["jennifer"]
CMD ["repl"]

# ---- static (distroless / :static) ----------------------------------------
FROM gcr.io/distroless/static-debian12:nonroot AS static
ARG VERSION=dev
LABEL org.opencontainers.image.title="Jennifer" \
      org.opencontainers.image.description="The Jennifer programming language interpreter (static/distroless; no /bin/sh, so os.run of external programs is unavailable)" \
      org.opencontainers.image.url="https://jennifer-lang.dev" \
      org.opencontainers.image.source="https://github.com/jennifer-language/jennifer" \
      org.opencontainers.image.licenses="LGPL-3.0-only" \
      org.opencontainers.image.version="${VERSION}"
COPY --from=build /out/jennifer /out/jennifer-tiny /usr/bin/
COPY --from=build /out/share /usr/share
COPY --from=build --chown=65532:65532 /out/work /work
WORKDIR /work
USER nonroot
ENTRYPOINT ["/usr/bin/jennifer"]
CMD ["repl"]
